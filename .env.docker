# MongoDB - Docker service name
MONGODB_URL=mongodb://mongodb:27017
MONGODB_DB_NAME=tiger_team

# Redis - Docker service name
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=demo-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# CORS - nginx serves on port 80
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:3000

# OAuth/OIDC (disabled for demo)
OAUTH_ENABLED=false

# Encryption key for provider API keys in database
FERNET_KEY=OMgcMuey-DF5abRMssqLdgFsibWa5zJqYQk_zu_g4L0=

# LLM Providers - add your API keys here
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Ollama - set to your Ollama server's address
# Local (Docker on Mac/Win): http://host.docker.internal:11434
# Remote: http://192.168.x.x:11434
# On Linux add: extra_hosts: ["host.docker.internal:host-gateway"] to backend service
OLLAMA_API_BASE=http://host.docker.internal:11434

# Qdrant - vector search
QDRANT_URL=http://qdrant:6333
