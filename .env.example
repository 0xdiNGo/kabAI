# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=kabai

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# OAuth/OIDC (optional)
OAUTH_ENABLED=false
OIDC_DISCOVERY_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# CORS (comma-separated origins; for Docker use http://localhost)
CORS_ORIGINS=http://localhost:5173

# LLM Providers (add API keys for providers you want to use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OLLAMA_API_BASE=http://localhost:11434

# Encryption key for storing provider API keys in the database
FERNET_KEY=
